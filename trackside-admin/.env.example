# ================== TRACKSIDE ADMIN — .env.example ==================
# Copy this file to .env.local and fill in real values. .env.local is
# gitignored and MUST stay that way — SUPABASE_SERVICE_ROLE_KEY grants
# full RLS bypass on the Supabase project.
#
# Variable scope reference:
#
#   NEXT_PUBLIC_*            inlined into the browser bundle by Next.js
#                            at build time. Safe for anon key only.
#
#   (no prefix)              never inlined into the browser. Available
#                            only at server runtime (Server Components,
#                            Route Handlers, Server Actions). REQUIRED
#                            posture for SUPABASE_SERVICE_ROLE_KEY.

# ---- Public (browser-safe) -------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...your-anon-key

# Origin used to build the magic-link `redirectTo` URL passed to
# Supabase Auth on sign-in. Must EXACTLY match an entry in the Supabase
# dashboard → Authentication → URL Configuration → "Redirect URLs"
# allowlist, otherwise Supabase will refuse to issue the magic link.
#
#   Local dev:    http://localhost:3000
#   Production:   https://your-admin-domain.example.com
#
# No trailing slash. The /auth/callback path is appended in code.
# In local dev this var is optional — the login page will fall back to
# the request's host header. In production it is REQUIRED so the email
# link doesn't point back to a preview domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Server only (must NOT be NEXT_PUBLIC_) -------------------------------
# Found in Supabase dashboard → Settings → API → "service_role" secret.
# This key bypasses RLS. If it ever ends up in the browser bundle the
# project is compromised — rotate immediately in the Supabase dashboard.
SUPABASE_SERVICE_ROLE_KEY=ey...your-service-role-key
