# Trackside Tales — Environment Variables
# Copy this file to .env and fill in your values.
# The app works fully without these (local data only).

# Supabase — enables remote content, QR validation, guest progress sync
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
